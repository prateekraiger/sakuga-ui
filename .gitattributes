# Set the default behavior to handle line endings automatically.
* text=auto

# Declare files that will always have LF line endings on checkout/checkin to prevent cross-platform mismatch.
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Denote all files that are binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
